-- Q16Find customers where city IS NOT NULL
SELECT * FROM customers WHERE city IS NULL;

-- Q17Find customers where city IS NOT NULL
SELECT * FROM customers WHERE city IS NOT NULL;

-- Q18Find total number of customers.
SELECT COUNT(*) FROM customers;

-- Q19Find average product price.
SELECT AVG(price) FROM products;

-- Q20Find maximum product price.
SELECT MAX(price) FROM products;

-- Q21Find total quantity sold.
SELECT SUM(quantity) FROM sales;

-- Q22Find number of products in each category.
SELECT category, COUNT(*) FROM products GROUP BY category;

-- Q23Find total sales quantity by product_id.
SELECT product_id, SUM(quantity) FROM sales GROUP BY product_id;

-- Q24Find average price by category.
SELECT category, AVG(price) FROM products GROUP BY category;

-- Q25Find categories where average price > 10,000.
SELECT category, AVG(price)
FROM products
GROUP BY category
HAVING AVG(price) > 10000;

-- Q26Find products where total quantity sold > 3.
SELECT product_id, SUM(quantity)
FROM sales
GROUP BY product_id
HAVING SUM(quantity) > 3;

-- Q27Find categories having more than 2 products.
SELECT category, COUNT(*)
FROM products
GROUP BY category
HAVING COUNT(*) > 2;

-- Q28Which category generates the most sales volume?
SELECT p.category, SUM(s.quantity)
FROM sales s
JOIN products p ON s.product_id = p.product_id
GROUP BY p.category
ORDER BY SUM(s.quantity) DESC
LIMIT 1;

-- Q29Which product sells the most units?
SELECT p.product_name, SUM(s.quantity)
FROM sales s
JOIN products p ON s.product_id = p.product_id
GROUP BY p.product_name
ORDER BY SUM(s.quantity) DESC
LIMIT 1;

-- Q30Which city has the most customers?
SELECT city, COUNT(*)
FROM customers
GROUP BY city
ORDER BY COUNT(*) DESC
LIMIT 1;

-- Q31Which product has the highest price?
SELECT product_name, price
FROM products
order by price DESC
Limit 1;